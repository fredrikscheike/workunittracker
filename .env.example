# Salesforce Connected App credentials
# Obtain from: Setup → App Manager → Work Unit Tracker → Manage Consumer Details
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Your Salesforce org URL (no trailing slash)
SF_INSTANCE_URL=https://trilogy-sales.my.salesforce.com

# Must match exactly what's registered in the Connected App callback URL
SF_REDIRECT_URI=https://workunittracker.vercel.app/api/auth/callback
